# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Test / pytest ─────────────────────────────────────────────────────────────
.pytest_cache/
pytest-cache-files-*/
.coverage
htmlcov/

# ── Models and runtimes (large binaries) ──────────────────────────────────────
models/
runtime/
*.gguf
*.bin
*.safetensors

# ── Runtime state (regenerated on each session) ───────────────────────────────
data/state/
data/debug/
data/vector_store/

# ── Benchmark artifacts ───────────────────────────────────────────────────────
data/benchmarks/bench_pids.txt

# ── User workspace (agent-generated files, not source) ────────────────────────
data/workspace/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

